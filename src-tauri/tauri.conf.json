{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "ToT 日程",
  "version": "0.1.1",
  "identifier": "com.tot.schedule",
  "build": {
    "beforeDevCommand": "npm run dev:web",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build:web",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "ToT 日程",
        "width": 1280,
        "height": 760,
        "minWidth": 980,
        "minHeight": 640,
        "center": true,
        "resizable": true,
        "dragDropEnabled": false,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "category": "Productivity",
    "shortDescription": "轻量本地日程与任务管理应用",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15",
      "signingIdentity": "-"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IERFNDFBMTA2RjkzQzZBRkYKUldUL2FqejVCcUZCM2dGaEJkaTkzZ1dZK1FrWjlpNEJGdzh2bmFOc2xGOC9LRkZjT1Z2Umt3UEQK",
      "endpoints": [
        "https://github.com/ToTXoX/ToT-schedule/releases/latest/download/latest.json"
      ]
    }
  }
}
